{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(awk:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:quarto.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:gist.githubusercontent.com)",
      "WebFetch(domain:docs.claude.com)",
      "Read(path:/Users/guilhermemarthe/dotfiles/**)",
      "Edit(path:/Users/guilhermemarthe/dotfiles/**)",
      "Write(path:/Users/guilhermemarthe/dotfiles/**)",
      "Read(path:/Users/guilhermemarthe/.claude/**)",
      "Edit(path:/Users/guilhermemarthe/.claude/**)",
      "Write(path:/Users/guilhermemarthe/.claude/**)",
      "Read(path:/Users/guilhermemarthe/.agents/**)",
      "Edit(path:/Users/guilhermemarthe/.agents/**)",
      "Write(path:/Users/guilhermemarthe/.agents/**)"
    ],
    "defaultMode": "default"
  },
  "model": "Opus",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'pane_active=$(tmux display-message -p \"#{pane_active}\" 2>/dev/null); if [ \"$pane_active\" != \"1\" ]; then osascript -e \"display notification \\\"Claude needs your approval\\\" with title \\\"Input Required\\\"\"; fi' 2>/dev/null || true",
            "statusMessage": "Notifying...",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'pane_active=$(tmux display-message -p \"#{pane_active}\" 2>/dev/null); if [ \"$pane_active\" != \"1\" ]; then osascript -e \"display notification \\\"Claude is waiting for your input\\\" with title \\\"Ready for Response\\\"\"; fi' 2>/dev/null || true",
            "statusMessage": "Notifying...",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true,
    "safety-net@cc-marketplace": true,
    "posit-dev@posit-dev-skills": true,
    "research-companion@andrehuang-research-companion": true,
    "quarto@posit-dev-skills": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "obsidian@obsidian-skills": true
  },
  "extraKnownMarketplaces": {
    "andrehuang-research-companion": {
      "source": {
        "source": "git",
        "url": "https://github.com/andrehuang/research-companion.git"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "effortLevel": "medium",
  "showClearContextOnPlanAccept": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
